# Supabase — put real values in .env.local only (gitignored). Do not commit secrets here.
# Vite loads .env then .env.local; .env.local overrides.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: where clients go after a successful claim (defaults to /)
# VITE_AFTER_CLAIM_REDIRECT=/

# Optional: used by contact/WhatsApp helpers if configured
# VITE_CONTACT_EMAIL_TO=

# Optional: staff invite magic-link redirect when running edge functions locally
# STAFF_CLAIM_REDIRECT=http://localhost:8082/staff/claim
